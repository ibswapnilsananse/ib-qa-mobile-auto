# >>>>>>>>>>>>>>>>>>>>>>>>>>>>>> Mobile Env
# Device Capabilities
IS_MOBILE_AUTOMATION=true
PLATFORM_NAME=android
PLATFORM_VERSION=12
DEVICE_NAME=Nexus 5

# Android Device ID / iOS UUID
UDID=emulator-5554

# Android App Package and App Activity >> Native APP
# For Google Dialer App (Native - no APK reset needed)
APP_PACKAGE=com.google.android.dialer
APP_ACTIVITY=com.google.android.dialer.extensions.GoogleDialtactsActivity
APK_FILE_PATH=
FULL_RESET=false

# For Hopper App (comment above and uncomment below to switch)
# APP_PACKAGE=com.hopper.mountainview.play
# APP_ACTIVITY=com.hopper.mountainview.activities.LaunchPage
# APK_FILE_PATH=app/hopper.apk
# FULL_RESET=true
AUTO_LAUNCH_APPIUM_SERVER=true
IMPLICITLY_WAIT=2000

# Test provider: local | headspin | browserstack
TEST_PROVIDER=local

# HeadSpin (used when TEST_PROVIDER=headspin)
HEADSPIN_API_TOKEN=your-headspin-api-token
HEADSPIN_HOST=appium-dev.headspin.io

# BrowserStack (used when TEST_PROVIDER=browserstack)
BROWSERSTACK_USER=your-browserstack-username
BROWSERSTACK_KEY=your-browserstack-access-key
BROWSERSTACK_APP_URL=bs://your-uploaded-app-id

# Test Data source
TEST_DATA_PATH=./TestData

# Skips the tests for blocked flows
SKIP_TEST=test_placeholder

# Jira Xray Integration Configuration
# Xray Cloud Configuration (for Xray Cloud with OAuth2)
XRAY_BASE_URL=https://xray.cloud.xpand-it.com
XRAY_CLIENT_ID=your-client-id
XRAY_CLIENT_SECRET=your-client-secret

# Project Configuration
JIRA_PROJECT_KEY=YOUR_PROJECT_KEY

# Optional: Specify an existing Test Execution key to update instead of creating a new one
# JIRA_TEST_EXECUTION_KEY=TEST-123

# Xray Report Configuration
XRAY_REPORT_FILE=./xray-report.json

# How to get Xray Client ID and Secret:
# 1. Go to your Xray Cloud instance
# 2. Navigate to API Keys / OAuth2 settings
# 3. Create a new client ID and secret
# 4. Copy and paste them here

# Usage:
# 1. Run tests with multi-reporter: npm run test:multi
# 2. Upload results to Xray: npm run xray:upload
