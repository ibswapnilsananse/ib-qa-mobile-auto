# >>>>>>>>>>>>>>>>>>>>>>>>>>>>>> Mobile Env
# Device Capabilities
IS_MOBILE_AUTOMATION=true
PLATFORM_NAME=android
PLATFORM_VERSION=12
DEVICE_NAME=Nexus 5

# Android Device ID / iOS UUID
UDID=emulator-5554

# Android App Package and App Activity >> Native APP
# For Google Dialer App (Native - no APK reset needed)
APP_PACKAGE=com.google.android.dialer
APP_ACTIVITY=com.google.android.dialer.extensions.GoogleDialtactsActivity
APK_FILE_PATH=
FULL_RESET=false

# For Hopper App (comment above and uncomment below to switch)
# APP_PACKAGE=com.hopper.mountainview.play
# APP_ACTIVITY=com.hopper.mountainview.activities.LaunchPage
# APK_FILE_PATH=app/hopper.apk
# FULL_RESET=true
AUTO_LAUNCH_APPIUM_SERVER=true
IMPLICITLY_WAIT=2000

# Test Data source
TEST_DATA_PATH=./TestData

# Skips the tests for blocked flows
SKIP_TEST=test_placeholder
